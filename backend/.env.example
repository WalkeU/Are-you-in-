# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (Postgres). In docker-compose the host is the service name "db".
DATABASE_URL=postgresql://areyouin:changeme@localhost:5432/areyouin?schema=public

# Auth secrets - generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS - comma separated list of allowed origins (mobile app uses no browser origin, keep for future web client)
CORS_ORIGINS=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Postgres container credentials (used by docker-compose only)
POSTGRES_USER=areyouin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=areyouin
